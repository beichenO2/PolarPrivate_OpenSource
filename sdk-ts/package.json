{
  "name": "privportal-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for PolarPrivate — sanitize/resolve middleware for LLM privacy",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./llm": {
      "import": "./dist/llm.js",
      "types": "./dist/llm.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "privacy",
    "sanitize",
    "pii",
    "llm",
    "middleware"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
